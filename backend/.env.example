# 复制此文件为 .env 并填入真实值

# 服务端口(前端 vite 代理固定指向 4000,改这里需同步改 frontend/vite.config.js）
BACKEND_PORT=4000

# 登录密码(简单口令鉴权;默认 admin 即可本地用）
APP_PASSWORD=admin

# JWT 签名密钥(随便填一串长随机字符）
JWT_SECRET=change-me-to-a-long-random-string

# ---- Telegram 发布(社群管理用）----
# 从 @BotFather 创建 bot 后拿到的 token
TELEGRAM_BOT_TOKEN=
# 目标频道/群的 chat id,如 @your_channel 或 -1001234567890
TELEGRAM_CHAT_ID=

# ---- AI 文案生成(社媒管理用,可选）----
# Anthropic API key(用于关键词 -> 推特文案）
ANTHROPIC_API_KEY=

# ---- X / Twitter 发布(社媒管理用）----
# 在 https://developer.x.com 创建 App,启用 Read and Write 权限后拿到这 4 个值
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
